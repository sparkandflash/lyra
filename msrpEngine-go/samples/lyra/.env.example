# ──────────────────────────────────────────────────────────────────
# BASE CONFIGURATION (Fallbacks)
# These values are used if an agent-specific variable is missing.
# ──────────────────────────────────────────────────────────────────
SYSTEM_API_KEY=your_default_api_key_here
SYSTEM_BASE_URL=https://api.example.com/v1
SYSTEM_MODEL=default-model-name
SYSTEM_PERSONALITY_NAME=lyra

# ──────────────────────────────────────────────────────────────────
# RESPONDER AGENT
# Handles the actual chat replies and character interaction.
# ──────────────────────────────────────────────────────────────────
SYSTEM_RESPONDER_TYPE=gemini
# SYSTEM_RESPONDER_API_KEY=
# SYSTEM_RESPONDER_BASE_URL=
# SYSTEM_RESPONDER_MODEL=
SYSTEM_RESPONDER_STM_CHARS=4000

# ──────────────────────────────────────────────────────────────────
# REACTOR AGENT
# Analyzes conversations to track emotional mindstate.
# ──────────────────────────────────────────────────────────────────
SYSTEM_REACTOR_TYPE=openai
SYSTEM_REACTOR_API_KEY=your_reactor_api_key
SYSTEM_REACTOR_BASE_URL=https://api.cerebras.ai/v1
SYSTEM_REACTOR_MODEL=gemma-4-31b
SYSTEM_REACTOR_CHAR_THRESHOLD=600

# ──────────────────────────────────────────────────────────────────
# SLEEP MODE
# ──────────────────────────────────────────────────────────────────
SYSTEM_TEMP_SLEEP_CYCLE_MINS=60

# ──────────────────────────────────────────────────────────────────
# SUMMARISER AGENT
# Generates episode summaries for long-term memory.
# ──────────────────────────────────────────────────────────────────
SYSTEM_SUMMARISER_TYPE=openai
SYSTEM_SUMMARISER_API_KEY=your_summariser_api_key
SYSTEM_SUMMARISER_BASE_URL=https://api.cerebras.ai/v1
SYSTEM_SUMMARISER_MODEL=gemma-4-31b

# ──────────────────────────────────────────────────────────────────
# ENGINE & MEMORY SETTINGS
# ──────────────────────────────────────────────────────────────────
SYSTEM_MAX_WORKING_MEMORY_CHARS=3000
SYSTEM_EPISODE_MEMORY_CHARS=8000
SYSTEM_TICK_SECONDS=5
SYSTEM_CONSOLIDATION_DENSITY=3000
SYSTEM_CONSOLIDATION_FREQ_MINS=1
SYSTEM_TRUE_SLEEP_DELAY_MINS=180
SYSTEM_TEMP_SLEEP_DELAY_MINS=5
