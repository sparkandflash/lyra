# ──────────────────────────────────────────────────────────────────
# BASE CONFIGURATION (Fallbacks)
# These values are used if an agent-specific variable is missing.
# ──────────────────────────────────────────────────────────────────
LYRA_API_KEY=your_default_api_key_here
LYRA_BASE_URL=https://api.example.com/v1
LYRA_MODEL=default-model-name

# ──────────────────────────────────────────────────────────────────
# RESPONDER AGENT
# Handles the actual chat replies and character interaction.
# ──────────────────────────────────────────────────────────────────
LYRA_RESPONDER_TYPE=gemini
# LYRA_RESPONDER_API_KEY=
# LYRA_RESPONDER_BASE_URL=
# LYRA_RESPONDER_MODEL=
LYRA_RESPONDER_STM_CHARS=4000

# ──────────────────────────────────────────────────────────────────
# REACTOR AGENT
# Analyzes conversations to track emotional mindstate.
# ──────────────────────────────────────────────────────────────────
LYRA_REACTOR_TYPE=openai
LYRA_REACTOR_API_KEY=your_reactor_api_key
LYRA_REACTOR_BASE_URL=https://api.cerebras.ai/v1
LYRA_REACTOR_MODEL=gemma-4-31b
LYRA_REACTOR_CHAR_THRESHOLD=600

# ──────────────────────────────────────────────────────────────────
# SUMMARISER AGENT
# Generates episode summaries for long-term memory.
# ──────────────────────────────────────────────────────────────────
LYRA_SUMMARISER_TYPE=openai
LYRA_SUMMARISER_API_KEY=your_summariser_api_key
LYRA_SUMMARISER_BASE_URL=https://api.cerebras.ai/v1
LYRA_SUMMARISER_MODEL=gemma-4-31b

# ──────────────────────────────────────────────────────────────────
# ENGINE & MEMORY SETTINGS
# ──────────────────────────────────────────────────────────────────
LYRA_MAX_WORKING_MEMORY_CHARS=3000
LYRA_EPISODE_MEMORY_CHARS=8000
LYRA_TICK_SECONDS=5
LYRA_CONSOLIDATION_DENSITY=3000
LYRA_CONSOLIDATION_FREQ_MINS=1
